# Never commit real credentials. Add your newly generated keys here.
PORT=3000
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Recommended: WATI third-party WhatsApp API. Get both values from WATI → API Docs.
WATI_API_ENDPOINT=https://live-mt-server.wati.io/your-tenant-id
WATI_API_TOKEN=
# The connected WATI channel / WhatsApp number, with country code and no +.
WATI_CHANNEL_NUMBER=

# Free unofficial WhatsApp Web connection. Set true, restart, then scan QR in Settings.
WHATSAPP_WEB_ENABLED=false

# Optional direct Meta WhatsApp Cloud API (used only when WATI is not configured)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Optional: Google Sheets webhook/API endpoint for contact mirroring
GOOGLE_SHEETS_WEBHOOK_URL=
